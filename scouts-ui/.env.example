# Local development defaults to browser storage. Do not set DATABASE_URL unless
# you intentionally want to test the real Prisma database path.

# Cloudflare Worker endpoint. Used for AI calls and Cloudflare Queue producer.
AI_WORKER_URL=http://localhost:8787
SCOUTS_QUEUE_API_URL=http://localhost:8787

# Internal callbacks. Local dev only.
APP_URL=http://localhost:3000
NEXT_PUBLIC_SCOUTS_LOCAL_ONLY=true
SCOUTS_LOCAL_ONLY=true
SCOUTS_INTERNAL_API_TOKEN=test-internal-token
