# Required: OpenRouter is the single model provider entrypoint.
OPENROUTER_API_KEY=your-openrouter-api-key

# Optional: Cloudflare AI Gateway.
# Requests go to: ${AI_GATEWAY_URL}/openrouter/chat/completions
AI_GATEWAY_URL=https://gateway.ai.cloudflare.com/v1/test-account/scouts-ai

# Required for Cloudflare Browser Run and optional AI Gateway auth.
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# App callback URL. In production set this to the deployed Scouts UI/API URL.
SCOUTS_APP_URL=http://localhost:3000
SCOUTS_INTERNAL_API_TOKEN=test-internal-token

# Optional: email notifications.
RESEND_API_KEY=your-resend-api-key
RESEND_FROM=ScoutsAI <noreply@example.com>
